# Supabase Configuration
# Get these values from your Supabase project settings (https://app.supabase.com)

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Airtable Configuration
# Get these values from your Airtable account (https://airtable.com/account)

# Your Airtable Personal Access Token
VITE_AIRTABLE_API_KEY=your-airtable-api-key-here

# Your Airtable Base ID (found in the URL: airtable.com/appXXXXXXXX/...)
VITE_AIRTABLE_BASE_ID=your-base-id-here

# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace the placeholder values with your actual Supabase and Airtable credentials
# 3. Never commit the .env file to version control
